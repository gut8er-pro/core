{
  "name": "gut8erpro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --config testing/e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config testing/e2e/playwright.config.ts --ui",
    "test:e2e:auth": "playwright test --config testing/e2e/playwright.config.ts 01-auth",
    "test:e2e:dashboard": "playwright test --config testing/e2e/playwright.config.ts 02-dashboard",
    "test:e2e:settings": "playwright test --config testing/e2e/playwright.config.ts 03-settings",
    "test:e2e:gallery": "playwright test --config testing/e2e/playwright.config.ts 04-gallery",
    "test:e2e:report-types": "playwright test --config testing/e2e/playwright.config.ts 05-report-types",
    "test:e2e:save": "playwright test --config testing/e2e/playwright.config.ts 06-save-reload",
    "test:e2e:condition": "playwright test --config testing/e2e/playwright.config.ts 07-condition",
    "test:e2e:calculation": "playwright test --config testing/e2e/playwright.config.ts 08-calculation",
    "test:e2e:invoice": "playwright test --config testing/e2e/playwright.config.ts 09-invoice",
    "test:e2e:export": "playwright test --config testing/e2e/playwright.config.ts 10-export",
    "test:e2e:edge": "playwright test --config testing/e2e/playwright.config.ts 11-edge-cases",
    "test:e2e:hs": "playwright test --config testing/e2e/playwright.config.ts 12-hs",
    "test:e2e:be": "playwright test --config testing/e2e/playwright.config.ts 13-be",
    "test:e2e:kg": "playwright test --config testing/e2e/playwright.config.ts 14-kg",
    "test:e2e:ot": "playwright test --config testing/e2e/playwright.config.ts 15-ot",
    "test:e2e:all-reports": "playwright test --config testing/e2e/playwright.config.ts 16-all-reports",
    "test:e2e:flows": "playwright test --config testing/e2e/playwright.config.ts 12-hs 13-be 14-kg 15-ot",
    "analyze": "ANALYZE=true next build",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-pdf/renderer": "^4.3.2",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.95.3",
    "@tanstack/react-query": "^5.90.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "fabric": "^7.1.0",
    "lucide-react": "^0.564.0",
    "next": "16.1.6",
    "pg": "^8.18.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "resend": "^6.9.2",
    "sharp": "^0.34.5",
    "stripe": "^20.3.1",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "biome check --write --unsafe --diagnostic-level=error",
      "biome format --write"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.4.0",
    "msw": "^2.12.10",
    "prisma": "^7.4.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
